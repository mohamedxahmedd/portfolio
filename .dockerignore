# Don't ship secrets or unnecessary bloat to the build context.

# Local environment
.env
.env.*
!.env.example

# Git + IDE
.git
.gitignore
.gitattributes
.idea
.vscode
.zed
.nova
.cursor
.codex

# Dependencies are rebuilt in their own stages
/vendor
/node_modules

# Built artefacts (Vite rebuilds in the assets stage)
/public/build
/public/hot
/public/storage

# Generated framework caches
/storage/logs
/storage/framework/cache/data
/storage/framework/sessions
/storage/framework/views
/storage/framework/testing
/storage/pail
/storage/debugbar
/storage/clockwork
/storage/*.key

# Local SQLite databases — production uses MySQL
*.sqlite
*.sqlite-journal
database/*.sqlite*

# Logs / scratch files
*.log
.phpunit.result.cache
.phpunit.cache
_ide_helper.php
_ide_helper_models.php
.phpactor.json

# OS junk
.DS_Store
Thumbs.db

# Docs that don't belong in the image
README.md
CHANGELOG.md
LICENSE
docs/

# Oracle-Cloud deploy scripts aren't needed on Render
/deploy
