# ============================================================================
#  Mohamed's Portfolio — environment template
#
#  This file is committed (NO secrets here). Copy to .env locally
#  (`cp .env.example .env`) or paste these keys into Render's "Environment"
#  panel for production. Render injects them as real env vars at runtime.
#
#  Required at deploy time:
#    APP_KEY              — generate locally with `php artisan key:generate
#                            --show` and paste the base64:… value.
#    DB_HOST/DATABASE/    — from your MySQL provider (TiDB Cloud, Aiven, etc.)
#    USERNAME/PASSWORD
# ============================================================================

APP_NAME="Mohamed's Portfolio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mohamed-portfolio.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Render captures stderr as service logs — keep stderr for log aggregation
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ───────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
# Some managed MySQL providers require TLS. Uncomment and point at the CA cert
# bundle inside the container if so. For PlanetScale/TiDB/Aiven use:
#   MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt
# MYSQL_ATTR_SSL_CA=

# ─── Sessions / Cache / Queue / Filesystem ─────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local
# Spatie Media Library uploads land on the "public" disk so they're servable
# via /storage/<id>/<file>. ⚠️  WARNING: Render's free filesystem is
# EPHEMERAL — every redeploy wipes uploaded files. See README for the
# Cloudflare R2 / S3 / Cloudinary migration path.
MEDIA_DISK=public

# ─── Filament admin ────────────────────────────────────────────────────────
FILAMENT_PATH=admin

# ─── Mail (optional — leave on `log` until you wire a real SMTP) ───────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@mohamed-portfolio.com"
MAIL_FROM_NAME="${APP_NAME}"

# Switch to SMTP when you have a Brevo/Mailgun/Postmark key:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# ─── (Optional) S3-compatible disk for media if you wire R2 / S3 later ─────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Frontend ──────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
